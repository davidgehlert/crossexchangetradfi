# =============================================================================
# SPY arbitrage bot config. Copy this file to ".env" and fill in your values.
# NEVER commit your real .env file. It contains secrets.
# =============================================================================

# ----- Run mode -----------------------------------------------------------
# DRY_RUN=true  -> compute signals and log intended trades, but place NOTHING.
# DRY_RUN=false -> actually place orders on the selected venues.
DRY_RUN=true

# HyperLiquid network: "testnet" or "mainnet". The xyz:SP500 perp lives on
# mainnet; the dashboard only READS public prices, so this is safe for monitoring.
HL_NETWORK=mainnet

# Comparison-leg backend for the spread:
#   "capital" - Capital.com US500 CFD via API (demo or live), macOS-friendly
#   "yahoo"   - free S&P 500 market data, no account, works on macOS
#   "mt5"     - real MetaTrader 5 broker feed (Windows only)
#   "paper"   - simulated, mirrors HyperLiquid (spread ~0 unless PAPER_SIMULATE)
BROKER=yahoo

# ----- HyperLiquid credentials -------------------------------------------
# The wallet/account address you trade with (0x...).
HL_ACCOUNT_ADDRESS=
# Private key of the API wallet used for signing (0x...). Use an API wallet,
# NOT your main wallet key. Generate one in the HyperLiquid UI.
HL_API_SECRET_KEY=

# ----- MetaTrader 5 credentials (only used when BROKER=mt5) ---------------
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Optional explicit path to terminal64.exe if not auto-detected.
MT5_TERMINAL_PATH=

# ----- Capital.com credentials (only used when BROKER=capital) -----------
CAPITAL_API_KEY=
CAPITAL_IDENTIFIER=
CAPITAL_PASSWORD=
CAPITAL_DEMO=true
CAPITAL_EPIC=US500

# ----- Symbols ------------------------------------------------------------
# HyperLiquid S&P 500 perp. It's a builder-deployed (HIP-3) market on the "xyz"
# dex, so set both the coin ticker and the dex name.
HL_SYMBOL=xyz:SP500
HL_DEX=xyz
# Yahoo Finance symbol for the comparison leg (used when BROKER=yahoo).
#   ^GSPC = S&P 500 cash index (matches the HL perp ~1:1)
#   ^SPX  = alt index symbol,  SPY = the ETF (~1/10 the index, set PRICE_RATIO)
YAHOO_SYMBOL=^GSPC
# Matching instrument on MetaTrader 5 (only used when BROKER=mt5).
MT5_SYMBOL=US500

# Multiply the comparison price by this to match the HL scale.
# HL S&P500 perp ≈ the cash index, so with YAHOO_SYMBOL=^GSPC keep 1.0.
# If you compare against the SPY ETF (~1/10 the index), use ~10.0, etc.
PRICE_RATIO=1.0

# ----- Strategy parameters ------------------------------------------------
# Enter a hedged position when |normalized spread| (in bps) exceeds this.
ENTRY_SPREAD_BPS=15
# Close the hedged position when |normalized spread| (in bps) falls below this.
EXIT_SPREAD_BPS=3
# Position size per leg, in units of the underlying (e.g. SPY shares/contracts).
POSITION_SIZE=1
# Maximum number of simultaneous hedged positions.
MAX_OPEN_POSITIONS=1

# ----- Risk / loop --------------------------------------------------------
# Seconds between strategy evaluations.
POLL_INTERVAL_SECONDS=5
# Hard stop: if combined unrealized loss exceeds this (quote currency), flatten.
MAX_LOSS_USD=100

# ----- Spread sketch ------------------------------------------------------
# Width (number of points) of the live terminal spread sparkline.
SKETCH_WIDTH=60

# ----- Web dashboard ------------------------------------------------------
# How many hours of history the dashboard graph shows (and backfills).
DASHBOARD_WINDOW_HOURS=72
# Port to serve the dashboard on.
DASHBOARD_PORT=8000
